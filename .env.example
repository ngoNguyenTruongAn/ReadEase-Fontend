# ReadEase Frontend - Environment Variables
# Copy this file to .env before running the Vite app.

# Backend REST API base URL.
# Local backend default: http://localhost:3000/api/v1/
VITE_API_BASE_URL=http://localhost:3000/api/v1/

# Tracking WebSocket endpoint.
# Keep this aligned with the backend APP_PORT.
VITE_TRACKING_WS_URL=ws://localhost:3000/tracking

# Supabase project config used by the clinician content/storage flow.
# Use the public anon key only. Do not put service-role keys in frontend env files.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
